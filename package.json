{
  "name": "figma-format-parse",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "license": "UNLICENSED",
  "scripts": {
    "typecheck": "bun --filter '*' typecheck",
    "test": "bun --filter fig-kiwi test",
